# Edoofa AI Voice Note Automation Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# OpenAI API Key (Required for transcription & summary)
# If empty, the app will run with a beautiful smart simulated fallback
OPENAI_API_KEY=

# Groq API Key (High-Speed & Cost-Effective Fallback)
# If empty, the app will check for OpenAI, then fall back to offline simulation
GROQ_API_KEY=

# Google Sheets Configuration
# To connect to real Google Sheets:
# 1. Place your service account JSON file as 'credentials.json' in the root directory.
# 2. Set your Google Spreadsheet ID here.
# 3. Share the Google Sheet with your service account email (found in credentials.json).
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=Sheet1

# Storage Settings
WHATSAPP_SESSION_PATH=./.wwebjs_auth
DATA_DIR=./data
AUDIO_DIR=./data/audio
MOCK_SHEET_PATH=./data/mock_sheets.json
